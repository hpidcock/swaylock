#!/usr/bin/make -f

ZIG_FLAGS =

ifneq (,$(filter true,$(CFG_DEBUG)))
ZIG_FLAGS += -Ddebug-overlay=true -Ddebug-unlock-on-crash=true
else
ZIG_FLAGS += -Doptimize=ReleaseSafe
endif

%:
	dh $@

override_dh_auto_configure:

override_dh_auto_build:
	scdoc < swaylock.1.scd > swaylock.1

override_dh_auto_test:

override_dh_auto_install:
	zig build $(ZIG_FLAGS) \
		-Dgdk-pixbuf=true \
		--prefix $(CURDIR)/debian/swaylock-authd/usr
	install -Dm644 swaylock.1 \
		$(CURDIR)/debian/swaylock-authd/usr/share/man/man1/swaylock.1
	install -Dm644 completions/bash/swaylock \
		$(CURDIR)/debian/swaylock-authd/usr/share/bash-completion/completions/swaylock
	install -Dm644 completions/zsh/_swaylock \
		$(CURDIR)/debian/swaylock-authd/usr/share/zsh/vendor-completions/_swaylock
	install -Dm644 completions/fish/swaylock.fish \
		$(CURDIR)/debian/swaylock-authd/usr/share/fish/vendor_completions.d/swaylock.fish

override_dh_strip:
	$(if $(filter true,$(CFG_DEBUG)),true,dh_strip)

override_dh_fixperms:
	dh_fixperms -Xswaylock
	chmod 4755 debian/swaylock-authd/usr/bin/swaylock
